page {
  min-height: 100vh;
  background: #f7f9fa;
  color: #172429;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
  letter-spacing: 0;
}

view,
text,
button,
input,
picker,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  line-height: normal;
  font: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.card {
  background: #ffffff;
  border: 1rpx solid #d9e3e2;
  border-radius: 16rpx;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  min-height: 92rpx;
  border-radius: 16rpx;
  background: #168b62;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
}

.field {
  margin-bottom: 28rpx;
}

.field-label {
  display: block;
  margin-bottom: 14rpx;
  color: #35484f;
  font-size: 26rpx;
  font-weight: 800;
}

.control {
  width: 100%;
  min-height: 84rpx;
  border: 1rpx solid #d9e3e2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #172429;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.muted {
  color: #65747a;
}
