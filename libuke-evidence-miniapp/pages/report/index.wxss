.report-page {
  padding-top: 24rpx;
}

.community-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 96rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.community-name {
  flex: 1;
  min-width: 0;
  color: #172429;
  font-size: 30rpx;
  font-weight: 800;
}

.choose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  width: 176rpx;
  min-height: 68rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid #b9ded0;
  border-radius: 16rpx;
  background: #e8f6f0;
  color: #0d6548;
  font-size: 28rpx;
  font-weight: 800;
}

.form-card {
  padding: 28rpx;
}

.picker-control {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chevron {
  color: #52676d;
  font-size: 32rpx;
}

.map-box {
  position: relative;
  width: 100%;
  height: 236rpx;
  overflow: hidden;
  border: 1rpx solid #cddfdf;
  border-radius: 16rpx;
  background: #eef6f5;
}

.map {
  width: 100%;
  height: 100%;
}

.map-location-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  width: 24rpx;
  height: 24rpx;
  border: 5rpx solid #ffffff;
  border-radius: 999rpx;
  background: #1677ff;
  box-shadow: 0 4rpx 14rpx rgba(22, 119, 255, .36);
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}

.map-location-dot::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: rgba(22, 119, 255, .16);
  transform: translate(-50%, -50%);
}

.map-label {
  position: absolute;
  left: 20rpx;
  bottom: 20rpx;
  z-index: 2;
  max-width: 560rpx;
  min-height: 56rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #d9e3e2;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .92);
  color: #3c555c;
  font-size: 24rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  box-sizing: border-box;
}

.location-warning {
  display: block;
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #f1c9a9;
  border-radius: 14rpx;
  background: #fff7ed;
  color: #a65016;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.location-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.location-action {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #d9e3e2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #52676d;
  font-size: 28rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.location-action.primary {
  border-color: #b9ded0;
  background: #e8f6f0;
  color: #0d6548;
}

.upload-grid {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-items: flex-start;
  gap: 16rpx;
}

.upload-tile {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
  margin: 0;
  padding: 0;
  min-height: 0;
  border: 1rpx dashed #b7c8cd;
  border-radius: 16rpx;
  background: #f6f8f8;
  color: #65747a;
  font-size: 44rpx;
  font-weight: 300;
  overflow: hidden;
}

.add-upload {
  width: 144rpx;
  height: 144rpx;
}

.upload-tile.filled {
  border-style: solid;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.remove-image-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  z-index: 2;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(13, 28, 34, .72);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

.submit-row {
  width: 100%;
  box-sizing: border-box;
  margin-top: 8rpx;
}

.submit-btn {
  width: 100%;
  height: 80rpx;
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 16rpx;
  background: #168b62;
  color: #ffffff;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1;
  box-sizing: border-box;
}

.history-row {
  width: 100%;
  box-sizing: border-box;
  margin-top: 16rpx;
}

.history-btn {
  width: 100%;
  height: 72rpx;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: 1rpx solid #d9e3e2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #52676d;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
  box-sizing: border-box;
}

.primary-btn {
  width: 100%;
}

.remark-control {
  display: block;
  width: 100%;
  min-height: 84rpx;
  height: 84rpx;
  max-width: 100%;
  padding: 0 24rpx;
  border: 1rpx solid #d9e3e2;
  border-radius: 16rpx;
  background: #ffffff;
  color: #172429;
  font-size: 30rpx;
  line-height: 84rpx;
  box-sizing: border-box;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  padding: 28rpx;
  background: rgba(12, 24, 29, .42);
}

.modal {
  width: 100%;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 20rpx 20rpx;
  background: #ffffff;
  box-shadow: 0 -24rpx 56rpx rgba(17, 32, 37, .16);
}

.modal-title {
  display: block;
  margin-bottom: 12rpx;
  color: #172429;
  font-size: 36rpx;
  font-weight: 900;
}

.modal-desc {
  display: block;
  margin-bottom: 28rpx;
  color: #65747a;
  font-size: 26rpx;
  line-height: 1.5;
}

.input-control {
  display: block;
}

.modal-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  column-gap: 20rpx;
  width: 100%;
  overflow: hidden;
}

.secondary-btn,
.confirm-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  min-height: 88rpx;
  margin: 0;
  padding: 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.secondary-btn {
  border: 1rpx solid #d9e3e2;
  background: #edf3f5;
  color: #274047;
}

.confirm-btn {
  border: 1rpx solid #168b62;
  background: #168b62;
  color: #ffffff;
}
