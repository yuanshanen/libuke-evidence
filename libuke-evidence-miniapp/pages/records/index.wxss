.records-page {
  padding-top: 24rpx;
}

.search-select {
  position: relative;
  min-width: 0;
  margin-bottom: 24rpx;
}

.search-icon {
  position: absolute;
  left: 28rpx;
  top: 50%;
  z-index: 1;
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid #5f747a;
  border-radius: 50%;
  transform: translateY(-58%);
  pointer-events: none;
}

.search-icon::after {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 22rpx;
  width: 16rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #5f747a;
  transform: rotate(45deg);
}

.filter-control {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  min-height: 84rpx;
  padding-left: 84rpx;
}

.record-list {
  display: grid;
  gap: 18rpx;
}

.report-card {
  position: relative;
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr) 28rpx;
  gap: 20rpx;
  align-items: center;
  min-width: 0;
  padding: 20rpx;
}

.thumb {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  border: 1rpx solid #cfe1df;
  border-radius: 16rpx;
  background: #eef6f3;
  overflow: hidden;
}

.thumb.facility {
  background:
    linear-gradient(145deg, rgba(40, 104, 184, .2), rgba(22, 139, 98, .12)),
    linear-gradient(45deg, #e1ebf6 0 48%, #f7faf9 48% 100%);
  color: #2868b8;
}

.thumb-image,
.thumb-placeholder {
  width: 100%;
  height: 100%;
}

.thumb-placeholder {
  background:
    linear-gradient(145deg, rgba(22, 139, 98, .24), rgba(40, 104, 184, .12)),
    linear-gradient(45deg, #d9eee5 0 45%, #f7faf9 45% 100%);
}

.image-badge {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  min-width: 52rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: rgba(23, 36, 41, .74);
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 800;
}

.record-main {
  display: grid;
  grid-template-rows: repeat(3, 1fr);
  row-gap: 6rpx;
  min-width: 0;
}

.record-title-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 16rpx;
  align-items: center;
  min-width: 0;
}

.record-title,
.record-sub,
.record-time {
  display: block;
  min-width: 0;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-title {
  color: #172429;
  font-size: 30rpx;
  font-weight: 900;
}

.status-badge {
  min-width: 92rpx;
  min-height: 42rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #e8f6f0;
  color: #0d6548;
  font-size: 22rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.status-badge.assigned,
.status-badge.processing {
  background: #eef5ff;
  color: #2367b3;
}

.status-badge.resolved,
.status-badge.closed {
  background: #edf3f5;
  color: #52676d;
}

.status-badge.invalid,
.status-badge.duplicate {
  background: #fff7ed;
  color: #a65016;
}

.record-sub {
  color: #35484f;
  font-size: 27rpx;
  font-weight: 800;
}

.record-time {
  display: block;
  color: #65747a;
  font-size: 24rpx;
  font-weight: 700;
}

.card-arrow {
  color: #91a1a6;
  font-size: 42rpx;
  line-height: 1;
}

.empty-state {
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #65747a;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #d9e3e2;
  border-radius: 24rpx;
  background:
    linear-gradient(#ffffff, #ffffff) padding-box,
    repeating-linear-gradient(0deg, #d9e3e2 0 2rpx, transparent 2rpx 18rpx);
  box-shadow: inset 0 0 0 18rpx #f6f8f8;
}
